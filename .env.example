# StreamHub environment variables — copy to .env and fill in.
# All values are optional. The app works without them (demo providers + stub subtitles).

# TMDB — get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb — get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# OpenSubtitles — get a key at https://www.opensubtitles.com/consumers
OPENSUBTITLES_API_KEY=

# SubDL — get a key at https://subdl.com/api
SUBDL_API_KEY=

# Admin PIN (set via /admin on first run instead — this is the bcrypt hash)
ADMIN_PIN_HASH=
