<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Settings"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Point StreamHub at your server. For the Android emulator, use http://10.0.2.2:3000. For a real device, use your computer's LAN IP (e.g. http://192.168.1.50:3000)."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/server_url"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/url_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/server_url_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"
            android:padding="14dp"
            android:background="@color/surface"
            android:inputType="textUri"
            android:autofillHints="url"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/test_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Test"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/reset_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reset"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/save_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:text="@string/save"
                android:backgroundTint="@color/accent"
                android:textColor="@color/white" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="32dp"
            android:background="@color/surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="StreamHub v1.0"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Personal self-hosted streaming PWA"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
